# Build outputs. The trailing slash matters: it matches the build/ directories and never the
# build.gradle files.
build/
.gradle/
target/
!gradle/wrapper/gradle-wrapper.jar

.idea/
*.iml
.vscode/
.settings/
.classpath
.project

# Terraform. The state is the map of everything that exists in AWS and it holds resource
# attributes in the clear -- it belongs in S3, never in git.
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfplan
crash.log
.terraform.lock.hcl

.env
*.log
.DS_Store
